#!/usr/bin/env python3
"""verify — the congruency verification suite (python, relocatable, registry-gated).

Modernises the old bash `verify` (kept as verify.bash.retired) that hardcoded the deleted
~/congruency-* paths. Runs every suite that applies to THIS tree and exits with the number
of FAILED suites (0 = all good). Emits a run_verify-parseable summary line:

    N suites passed, M failed

Suites:
  * stand_up     boot the CMS (checkouts/current/boot/router.php) on the provisioned php
                 and assert HTTP 200 / no fatal on real pages          [the pass/fail gate]
  * bug_catalog  run tooling/congruencey-bugs/harness.php against the real source; report
                 how many of the 15 catalogued bugs still reproduce (this source is the
                 evolved tournament winner, so some are legitimately fixed — informational,
                 fails only if the harness itself cannot run)
  * phpunit      run vendor/bin/phpunit if installed, else SKIP
  * branch_cov   run coverage/branch_test*.php if their target resolves, else SKIP

python only (no shell). Paths derived from __file__. Registry-gated: throws if it cannot
see registry.json.
"""
import json
import os
import re
import socket
import subprocess
import sys
import time
import urllib.error
import urllib.request

HERE = os.path.dirname(os.path.abspath(__file__))                 # tooling/congruencey-tests
MONO = os.path.dirname(os.path.dirname(HERE))                     # repo/package root
SOURCE = os.path.join(MONO, "checkouts", "current")              # the congruency source (winner)
BUGS_HARNESS = os.path.join(MONO, "tooling", "congruencey-bugs", "harness.php")
COVERAGE = os.path.join(MONO, "tooling", "coverage")
ROUTER = os.path.join("boot", "router.php")                      # relative to SOURCE (cwd)
PAGES = ["?page=catalog&fresh=1", "?page=about", "?page=catalog"]
FATAL = ("Fatal error", "Parse error", "Uncaught", "PHP Fatal", "Stack trace")


def find_registry(start=HERE):
    d = os.path.abspath(start)
    while True:
        cand = os.path.join(d, "registry.json")
        if os.path.isfile(cand):
            return cand
        parent = os.path.dirname(d)
        if parent == d:
            raise FileNotFoundError("registry.json not found at/above %s" % start)
        d = parent


def load_registry():
    path = find_registry()
    reg = json.load(open(path))
    reg["__root__"] = os.path.dirname(path)
    return reg


def find_php(reg):
    rel = (reg.get("paths", {}) or {}).get("php", "tooling/congruencey-harness/php/php")
    p = os.path.join(reg["__root__"], rel)
    if not os.path.isfile(p):
        raise FileNotFoundError("php not provisioned at %s — run provision_php.py first" % p)
    return p


# --------------------------------------------------------------------------- #
# suites — each returns (status, detail) with status in PASS/FAIL/SKIP         #
# --------------------------------------------------------------------------- #
def _free_port():
    s = socket.socket()
    s.bind(("127.0.0.1", 0))
    p = s.getsockname()[1]
    s.close()
    return p


def _probe(url):
    try:
        with urllib.request.urlopen(url, timeout=8) as r:
            return r.status, r.read(8000).decode("utf-8", "replace")
    except urllib.error.HTTPError as e:
        return e.code, e.read(8000).decode("utf-8", "replace")
    except Exception as e:  # noqa: BLE001
        return None, "%r" % e


def suite_stand_up(php):
    if not os.path.isfile(os.path.join(SOURCE, ROUTER)):
        return "FAIL", "new-tree router missing at %s" % os.path.join(SOURCE, ROUTER)
    port = _free_port()
    proc = subprocess.Popen([php, "-S", "127.0.0.1:%d" % port, ROUTER], cwd=SOURCE,
                            stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    time.sleep(1.5)
    rows, first = [], ""
    try:
        for pg in PAGES:
            st, body = _probe("http://127.0.0.1:%d/%s" % (port, pg))
            rows.append((pg, st))
            if not first:
                first = body
    finally:
        proc.terminate()
        try:
            _o, serr = proc.communicate(timeout=5)
        except Exception:  # noqa: BLE001
            proc.kill()
            _o, serr = proc.communicate()
    all200 = all(st == 200 for _, st in rows)
    fatal = any(m in (first + (serr or "")) for m in FATAL)
    ok = all200 and not fatal
    detail = "pages=%s%s" % (rows, "" if not fatal else "  FATAL in output")
    return ("PASS" if ok else "FAIL"), detail


def suite_bug_catalog(php):
    if not os.path.isfile(BUGS_HARNESS):
        return "SKIP", "no bug harness at %s" % BUGS_HARNESS
    env = dict(os.environ, CONGRUENCEY_PATH=SOURCE)
    r = subprocess.run([php, BUGS_HARNESS], cwd=os.path.dirname(BUGS_HARNESS),
                       env=env, capture_output=True, text=True, timeout=180)
    out = r.stdout + r.stderr
    m = re.search(r"(\d+)\s+reproduced,\s+(\d+)\s+failed,\s+(\d+)\s+total", out)
    if not m:
        return "FAIL", "harness produced no catalog summary (exit %s)" % r.returncode
    repro, notrepro, total = m.groups()
    # This is the evolved winner source: not-reproduced == fixed, which is fine. The suite
    # passes as long as the harness ran and produced a valid catalog result.
    return "PASS", "%s/%s bugs reproduce (%s fixed in this source)" % (repro, total, notrepro)


def suite_phpunit(php):
    phpunit = os.path.join(HERE, "vendor", "bin", "phpunit")
    if not os.path.isfile(phpunit):
        return "SKIP", "vendor/bin/phpunit not installed (composer install needed)"
    r = subprocess.run([php, phpunit], cwd=HERE, capture_output=True, text=True, timeout=240)
    return ("PASS" if r.returncode == 0 else "FAIL"), (r.stdout or r.stderr).strip().splitlines()[-1:]


def suite_branch_cov(php):
    test = os.path.join(COVERAGE, "branch_test.php")
    if not os.path.isfile(test):
        return "SKIP", "no coverage/branch_test.php"
    # The coverage scripts still hardcode the old ~/congruency target path; skip until they
    # are repathed to checkouts/current (tracked separately).
    src = open(test).read()
    if "/home/notificationsforsteven/congruency/" in src:
        return "SKIP", "branch_test.php hardcodes a dead ~/congruency path (needs repathing)"
    r = subprocess.run([php, test], cwd=COVERAGE, capture_output=True, text=True, timeout=120)
    return ("PASS" if r.returncode == 0 else "FAIL"), (r.stdout or r.stderr).strip().splitlines()[-1:]


def main():
    reg = load_registry()
    php = find_php(reg)

    suites = [
        ("stand_up (HTTP 200)", suite_stand_up),
        ("bug_catalog",         suite_bug_catalog),
        ("phpunit",             suite_phpunit),
        ("branch_cov",          suite_branch_cov),
    ]
    passed = failed = skipped = 0
    print("\ncongruency verify — source: %s" % os.path.relpath(SOURCE, MONO))
    print("php: %s\n" % os.path.relpath(php, MONO))
    for name, fn in suites:
        try:
            status, detail = fn(php)
        except Exception as exc:  # noqa: BLE001
            status, detail = "FAIL", "%s: %s" % (type(exc).__name__, exc)
        mark = {"PASS": ">> PASS", "FAIL": ">> FAIL", "SKIP": "-- SKIP"}[status]
        print("%s: %-22s %s" % (mark, name, detail))
        passed += status == "PASS"
        failed += status == "FAIL"
        skipped += status == "SKIP"

    print("\n" + "=" * 56)
    print("  %d suites passed, %d failed (%d skipped)" % (passed, failed, skipped))
    print("=" * 56)
    return failed


if __name__ == "__main__":
    sys.exit(main())
