#!/usr/bin/env bash
# Seed the demo database and serve the resurrected congruency CMS.
#   ./serve            seed + start the dev server on :8899
#   ./serve --no-seed  start without reseeding (keep current data)
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
PHP="${CONGRUENCEY_PHP:-$here/php/php}"
PORT="${PORT:-8899}"

if [ ! -x "$PHP" ]; then
  echo "No PHP at $PHP. Set CONGRUENCEY_PHP=/path/to/php (PHP 8)." >&2
  exit 127
fi

if [ "${1:-}" != "--no-seed" ]; then
  "$PHP" "$here/seed.php"
fi

echo "serving http://0.0.0.0:$PORT/?page=catalog   (Ctrl-C to stop)"
echo "pages: catalog | about | bugs | forms   (add ?fresh=1 after adding tags/forms)"
exec "$PHP" -S "0.0.0.0:$PORT" "$here/router.php"
