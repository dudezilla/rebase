# rebase — installer (setup.py) + CMS source, one branch.
# Keep runtime/build/provisioned artifacts out of git.

__pycache__/
*.pyc
*~
*.sqlite

# provisioned / installed into the working tree at runtime by the installer:
/tooling/congruencey-harness/php/
/checkouts/current/state/congruency.sqlite
/checkouts/current/state/seed.php
/checkouts/current/install.json
# runtime-regenerated index (written by fixes/boot_www.py on stand-up) — keep it from dirtying the tree:
/checkouts/current/congruency/fixes/index.json

# logs
logs/
/logs/bug_reports.jsonl
/logs/predictions.jsonl
/logs/doc_watch.json

# tracker runtime
/tracker/serve.log
/tracker/project.db
tracker/project.db.superseded

# misc
tooling/congruencey-harness/wiz.txt
